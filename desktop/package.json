{
  "name": "desk-assistant-ai",
  "version": "1.0.1",
  "description": "Desk Assistant AI - An Intelligent Privacy-First File Management System",
  "main": "main.js",
  "author": "Shreyas Vengurlekar",
  "license": "ISC",
  "scripts": {
    "start": "electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder"
  },
  "build": {
    "appId": "com.shreyas.deskassistantai",
    "productName": "Desk Assistant AI",
    "publish": [
      {
        "provider": "github",
        "owner": "shreyasvengurlekar",
        "repo": "desk-assistant-ai-applicatio"
      }
    ],
    "directories": {
      "output": "dist"
    },
    "files": [
      "**/*"
    ],
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  },
  "devDependencies": {
    "electron": "^40.1.0",
    "electron-builder": "^25.1.8",
    "png-to-ico": "^3.0.1"
  },
  "dependencies": {
    "@google/genai": "^1.39.0",
    "dotenv": "^17.2.3",
    "electron-updater": "^6.8.3",
    "sqlite3": "^5.1.7"
  }
}